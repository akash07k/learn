{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "bracketSpacing": true,
  "ignorePatterns": ["**/*.md", "html", "node_modules", "bun.lock", "assets/pandoc-template.html"]
}
