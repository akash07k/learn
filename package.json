{
  "name": "learn",
  "version": "0.1.0",
  "private": true,
  "description": "An accessible, shell-first learning corpus.",
  "type": "module",
  "scripts": {
    "build": "bun run tools/build-html.ts",
    "build:changed": "bun run tools/build-html.ts --changed",
    "check": "bun run tools/check.ts",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "lint:js": "oxlint",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "ci:local": "bun run lint:js && bun run format:check && bun run lint:md && bun run typecheck && bun test && bun run check",
    "format": "oxfmt && bun run tools/format-md.ts",
    "format:check": "oxfmt --check && bun run tools/format-md.ts --check",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/bun": "^1.3.14",
    "lefthook": "^2.1.9",
    "markdownlint-cli2": "^0.22.1",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "oxlint-tsgolint": "^0.23.0",
    "prettier": "^3.8.4",
    "smol-toml": "^1.6.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.3.14 <2"
  }
}
